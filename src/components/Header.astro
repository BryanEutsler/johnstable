---
import { siteMeta } from "../data/site";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand-mark" href="/" aria-label={`${siteMeta.name} home`}>
      <span class="brand-mark__name">{siteMeta.name}</span>
      <span class="brand-mark__tag">{siteMeta.tagline}</span>
    </a>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
      <span class="sr-only">Toggle navigation</span>
      Menu
    </button>

    <nav id="site-nav" class="site-nav" aria-label="Primary">
      {
        siteMeta.navItems.map((item) => (
          <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const button = document.querySelector(".nav-toggle");
  const nav = document.querySelector("#site-nav");

  if (button instanceof HTMLButtonElement && nav instanceof HTMLElement) {
    button.addEventListener("click", () => {
      const next = nav.dataset.open !== "true";
      nav.dataset.open = String(next);
      button.setAttribute("aria-expanded", String(next));
    });
  }
</script>
