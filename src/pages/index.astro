---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projectHighlights, siteMeta, supportGroups, supportSheets } from "../data/site";
---

<BaseLayout
  title={`${siteMeta.name} | Community care through meals, clothing, and connection`}
  description={siteMeta.mission}
>
  <section class="home-hero">
    <div class="home-hero__inner">
      <div class="home-hero__content">
        <p class="eyebrow">{siteMeta.tagline}</p>
        <div class="hero-logo-lockup">
          <img class="hero-logo" src="/jt-logo.png" alt={`${siteMeta.name} logo`} />
        </div>
        <h1>A neighborhood table for meals, dignity, and next steps.</h1>
        <p class="lede">
          {siteMeta.name} exists to make care feel immediate and human: a meal first, then clothing,
          practical support, and a clearer path toward what comes next.
        </p>
        <div class="hero-pills">
          <span>Meals</span>
          <span>Clothing</span>
          <span>Resources</span>
          <span>Community support</span>
        </div>
        <div class="hero-actions">
          <a class="button button--primary" href="/donate">Donate</a>
          <a class="button button--secondary" href="/projects">View Projects</a>
          <a class="button button--secondary" href="/contact">Contact</a>
        </div>
        <p class="hero-note">
          This version gives John&apos;s Table a clearer public-facing story and stronger calls to action.
        </p>
      </div>

      <div class="home-hero__visual" aria-hidden="true">
        <div class="visual-panel">
          <div class="visual-panel__crest">John's Table</div>
          <p class="visual-panel__quote">Healing our community one meal at a time.</p>
          <div class="visual-panel__details">
            <div class="visual-chip">
              <strong>Care starts here</strong>
              <span>Food and essentials offered with dignity, not distance.</span>
            </div>
            <div class="visual-chip">
              <strong>Built for partnership</strong>
              <span>Ready for local sponsors, volunteers, and community allies.</span>
            </div>
            <div class="visual-chip">
              <strong>Made to grow</strong>
              <span>A stronger public site now, deeper stories and giving tools next.</span>
            </div>
          </div>
        </div>
        <div class="visual-tag visual-tag--top">501(c)(3)</div>
        <div class="visual-tag visual-tag--bottom">Community care, visibly organized</div>
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="section__inner">
      <div class="story-band" data-reveal>
        <span>Meals that gather people</span>
        <span>Clothing that restores comfort</span>
        <span>Resources that help people move forward</span>
        <span>Sponsors that help the work last</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section__inner">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">Mission and vision</p>
        <h2>Care that starts with the immediate need and keeps reaching outward.</h2>
        <p>
          The organization&apos;s current public message is simple and direct. This homepage gives that
          message stronger structure, warmer language, and a clearer path for supporters to respond.
        </p>
      </div>

      <div class="mission-grid">
        <article class="stack" data-reveal>
          <h3>Mission</h3>
          <p>{siteMeta.mission}</p>
        </article>
        <article class="stack" data-reveal>
          <h3>Vision</h3>
          <p>{siteMeta.vision}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="section__inner">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">What the work points toward</p>
        <h2>Three practical lanes the organization can speak about with confidence now.</h2>
        <p>
          Rather than padding the site with vague nonprofit language, the homepage keeps attention on the
          direct kinds of help already named in the existing public material.
        </p>
      </div>

      <div class="highlights">
        {
          projectHighlights.map((item, index) => (
            <article class="highlight" data-reveal>
              <span class="highlight__index">0{index + 1}</span>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section__inner sponsor-showcase">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">Sponsors and partners</p>
        <h2>John&apos;s Table is already surrounded by real community partners and benefactors.</h2>
        <p>
          Instead of abstract sponsor categories, this section now reflects the organizations and
          benefactors shown in the materials you provided.
        </p>
      </div>

      <div class="support-preview" data-reveal>
        <div class="support-preview__image">
          <img
            class="sponsor-image sponsor-image--sheet"
            src={supportSheets[0].image}
            alt={supportSheets[0].alt}
            loading="lazy"
          />
        </div>
        <div class="support-preview__content">
          {
            supportGroups.map((group) => (
              <article class="support-group">
                <h3>{group.title}</h3>
                <p>{group.intro}</p>
                <ul class="support-list" aria-label={group.title}>
                  {group.members.slice(0, 5).map((member) => <li>{member}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </div>

      <div class="cta-row" data-reveal>
        <a class="button button--primary" href="/community-partners-and-sponsors">
          View full partner list
        </a>
        <a class="button button--secondary" href="/contact">Start a partnership conversation</a>
      </div>
    </div>
  </section>

  <section class="section section--ink">
    <div class="section__inner">
      <div class="cta-panel cta-panel--ink" data-reveal>
        <p class="section__eyebrow">Give support a visible place</p>
        <h2>The donation page now explains how support can strengthen the work, even before online giving is connected.</h2>
        <p>
          That gives the client a realistic preview of how giving can be framed on the site without
          committing to a processor or donation workflow yet.
        </p>
        <div class="cta-row">
          <a class="button button--primary" href="/donate">Open donations page</a>
          <a class="button button--secondary" href="/contact">Contact</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
