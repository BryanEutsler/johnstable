---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projectHighlights, siteMeta, supporters } from "../data/site";

const featuredSupporters = supporters.slice(0, 8);
---

<BaseLayout
  title={`${siteMeta.name} | Community care through meals, clothing, and connection`}
  description={siteMeta.mission}
>
  <section class="home-hero">
    <div class="home-hero__inner">
      <div class="home-hero__content">
        <p class="eyebrow">{siteMeta.tagline}</p>
        <div class="hero-logo-lockup">
          <img class="hero-logo" src="/jt-logo.png" alt={`${siteMeta.name} logo`} />
        </div>
        <h1>A neighborhood table for meals, dignity, and next steps.</h1>
        <p class="lede">
          {siteMeta.name} exists to make care feel immediate and human: a meal first, then clothing,
          practical support, and a clearer path toward what comes next.
        </p>
        <div class="hero-pills">
          <span>Meals</span>
          <span>Clothing</span>
          <span>Resources</span>
          <span>Community support</span>
        </div>
        <div class="hero-actions">
          <a class="button button--primary" href="/donate">Donate</a>
          <a class="button button--secondary" href="/projects">View Projects</a>
          <a class="button button--secondary" href="/contact">Contact</a>
        </div>
      </div>

      <div class="home-hero__visual" aria-hidden="true">
        <div class="visual-panel">
          <div class="visual-panel__crest">John's Table</div>
          <p class="visual-panel__quote">Healing our community one meal at a time.</p>
          <div class="visual-panel__details">
            <div class="visual-chip">
              <strong>Care starts here</strong>
              <span>Food and essentials offered with dignity, not distance.</span>
            </div>
            <div class="visual-chip">
              <strong>Community rooted</strong>
              <span>Built around practical help, neighbor-to-neighbor support, and visible care.</span>
            </div>
            <div class="visual-chip">
              <strong>Backed by partners</strong>
              <span>Strengthened by local organizations, benefactors, and community collaboration.</span>
            </div>
          </div>
        </div>
        <div class="visual-tag visual-tag--top">501(c)(3)</div>
        <div class="visual-tag visual-tag--bottom">Serving the community one meal at a time</div>
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="section__inner">
      <div class="story-band" data-reveal>
        <span>Meals that gather people</span>
        <span>Clothing that restores comfort</span>
        <span>Resources that help people move forward</span>
        <span>Partners that help the work last</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section__inner">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">Mission and vision</p>
        <h2>Care that starts with the immediate need and keeps reaching outward.</h2>
        <p>
          The organization&apos;s public message is simple and direct. This homepage gives that message
          stronger structure, warmer language, and a clearer path for supporters to respond.
        </p>
      </div>

      <div class="mission-grid">
        <article class="stack" data-reveal>
          <h3>Mission</h3>
          <p>{siteMeta.mission}</p>
        </article>
        <article class="stack" data-reveal>
          <h3>Vision</h3>
          <p>{siteMeta.vision}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="section__inner">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">Areas of support</p>
        <h2>Three ways the work shows up in everyday community life.</h2>
        <p>
          The strongest public story here is practical: meals, essentials, and the kind of follow-through
          that helps people move toward greater stability.
        </p>
      </div>

      <div class="highlights">
        {
          projectHighlights.map((item, index) => (
            <article class="highlight" data-reveal>
              <span class="highlight__index">0{index + 1}</span>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section__inner sponsor-showcase">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">Partners and benefactors</p>
        <h2>John&apos;s Table is already supported by a visible network of community organizations and benefactors.</h2>
        <p>
          These are some of the organizations shown in the materials you provided, presented individually
          so the site reflects the real circle of support around the work.
        </p>
      </div>

      <div class="logo-grid logo-grid--homepage">
        {
          featuredSupporters.map((supporter) => (
            <article class="logo-card" data-reveal>
              <div class="logo-card__image-wrap">
                <img class="logo-card__image" src={supporter.image} alt={supporter.alt} loading="lazy" />
              </div>
              <div class="logo-card__meta">
                <span class="logo-card__group">{supporter.group}</span>
                <h3>{supporter.name}</h3>
              </div>
            </article>
          ))
        }
      </div>

      <div class="cta-row" data-reveal>
        <a class="button button--primary" href="/community-partners-and-sponsors">
          View all partners and benefactors
        </a>
        <a class="button button--secondary" href="/contact">Start a partnership conversation</a>
      </div>
    </div>
  </section>

  <section class="section section--ink">
    <div class="section__inner">
      <div class="cta-panel cta-panel--ink" data-reveal>
        <p class="section__eyebrow">Give support a visible place</p>
        <h2>The donation page explains how support can strengthen meals, essentials, and ongoing care.</h2>
        <p>
          It gives donors and supporters a clear understanding of where help can go while keeping the
          public story aligned with the mission.
        </p>
        <div class="cta-row">
          <a class="button button--primary" href="/donate">Open donations page</a>
          <a class="button button--secondary" href="/contact">Contact</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
