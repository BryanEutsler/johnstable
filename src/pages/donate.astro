---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { donationOptions, siteMeta } from "../data/site";
---

<BaseLayout title={`Donate | ${siteMeta.name}`} description="Support the work of John's Table.">
  <PageHero
    eyebrow="Donate"
    title="Give the mission a place to land."
    description="This page can connect to an online giving platform later without changing the overall story or layout."
  />

  <section class="page-content">
    <div class="section__inner">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">Ways to support</p>
        <h2>Three giving lanes that match the organization's current public story.</h2>
        <p>
          The goal of this page is clarity. It helps a prospective donor understand where support can go
          and why giving matters, even before online payments are turned on.
        </p>
      </div>

      <div class="donation-grid">
        {
          donationOptions.map((item) => (
            <article class="donation-card" data-reveal>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <span>{item.note}</span>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="section__inner">
      <div class="cta-panel" data-reveal>
        <p class="section__eyebrow">Ready for launch preparation</p>
        <h2>This page can easily grow into online giving, recurring support, or campaign storytelling.</h2>
        <p>
          When the organization selects a payment processor, the primary call to action here can become a
          direct giving link while keeping the same copy structure and visual hierarchy.
        </p>
        <div class="cta-row">
          <a class="button button--primary" href="/contact">Talk about giving</a>
          <a class="button button--secondary" href="/community-partners-and-sponsors">
            View sponsor page
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
