---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { donationOptions, siteMeta } from "../data/site";
---

<BaseLayout title={`Donate | ${siteMeta.name}`} description="Support the work of John's Table with a financial gift or in-kind donation.">
  <PageHero
    eyebrow="Donate"
    title="Give the mission a place to land."
    description="Your support helps keep the table open — ensuring neighbors have access to meals, clothing, and the resources that help care continue."
  />

  <section class="page-content">
    <div class="section__inner">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">Ways to support</p>
        <h2>Three giving lanes that match the heart of the work.</h2>
        <p>
          Whether you give once or regularly, your contribution goes directly toward the neighbors
          John's Table serves. Each lane below reflects a real area of the mission — choose the one
          that resonates most, or reach out to give across all three.
        </p>
      </div>

      <div class="donation-grid">
        {
          donationOptions.map((item) => (
            <article class="donation-card" data-reveal>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
              <span>{item.note}</span>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="section__inner">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">In-kind giving</p>
        <h2>Not all support comes as a check.</h2>
        <p>
          John's Table welcomes in-kind donations of food, clothing, and household essentials.
          If you or your organization would like to donate goods directly, reach out through the
          contact page and we'll coordinate the details with you.
        </p>
      </div>

      <div class="highlights">
        <article class="highlight" data-reveal>
          <span class="highlight__index">01</span>
          <h3>Food and groceries</h3>
          <p>
            Non-perishable food items, fresh produce, and packaged goods help extend the reach
            of every meal service.
          </p>
        </article>
        <article class="highlight" data-reveal>
          <span class="highlight__index">02</span>
          <h3>Clothing and essentials</h3>
          <p>
            Clean, gently used or new clothing for adults — especially coats, shoes, and
            seasonal items — makes a real difference for neighbors in need.
          </p>
        </article>
        <article class="highlight" data-reveal>
          <span class="highlight__index">03</span>
          <h3>Household and personal care items</h3>
          <p>
            Toiletries, hygiene products, and basic household goods round out the essentials
            support and help people feel restored.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--ink">
    <div class="section__inner">
      <div class="cta-panel cta-panel--ink" data-reveal>
        <p class="section__eyebrow">Ready to give?</p>
        <h2>Every contribution — large or small — helps keep care close to neighbors who need it.</h2>
        <p>
          To make a financial gift or arrange an in-kind donation, reach out through the contact
          page. We'll connect you with the right giving path and make sure your support lands
          where it can matter most.
        </p>
        <div class="cta-row">
          <a class="button button--primary" href="/contact">Start a giving conversation</a>
          <a class="button button--secondary" href="/community-partners-and-sponsors">
            Become a partner
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
