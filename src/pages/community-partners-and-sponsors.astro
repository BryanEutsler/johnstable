---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { siteMeta, supporters } from "../data/site";

const communityPartners = supporters.filter((supporter) => supporter.group === "Community Partner");
const benefactors = supporters.filter((supporter) => supporter.group === "Benefactor");
---

<BaseLayout
  title={`Community Partners & Sponsors | ${siteMeta.name}`}
  description="Community partners and benefactors supporting John's Table."
>
  <PageHero
    eyebrow="Community partners and sponsors"
    title="The work is strengthened by a real circle of partners and benefactors."
    description="Each organization shown here comes from the materials you shared and is now presented individually rather than as a collage sheet."
  />

  <section class="page-content">
    <div class="section__inner support-section">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">Community partners</p>
        <h2>Organizations helping strengthen outreach, recovery support, and local connection.</h2>
        <p>
          These partners reflect the collaborative network surrounding John&apos;s Table and the wider
          community work connected to care, recovery, and direct support.
        </p>
      </div>

      <div class="logo-grid">
        {
          communityPartners.map((supporter) => (
            <article class="logo-card" data-reveal>
              <div class="logo-card__image-wrap">
                <img class="logo-card__image" src={supporter.image} alt={supporter.alt} loading="lazy" />
              </div>
              <div class="logo-card__meta">
                <span class="logo-card__group">{supporter.group}</span>
                <h3>{supporter.name}</h3>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="page-content page-content--tight">
    <div class="section__inner support-section">
      <div class="section__intro" data-reveal>
        <p class="section__eyebrow">Benefactors</p>
        <h2>Businesses, organizations, and supporters helping make the mission possible.</h2>
        <p>
          This group reflects the benefactors visible in the materials you shared, presented here as
          individual organizations instead of grouped source images.
        </p>
      </div>

      <div class="logo-grid">
        {
          benefactors.map((supporter) => (
            <article class="logo-card" data-reveal>
              <div class="logo-card__image-wrap">
                <img class="logo-card__image" src={supporter.image} alt={supporter.alt} loading="lazy" />
              </div>
              <div class="logo-card__meta">
                <span class="logo-card__group">{supporter.group}</span>
                <h3>{supporter.name}</h3>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
