---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { siteMeta, sponsorProfiles } from "../data/site";
---

<BaseLayout
  title={`Community Partners & Sponsors | ${siteMeta.name}`}
  description="A page shell for future partners, sponsors, and community collaboration."
>
  <PageHero
    eyebrow="Community partners and sponsors"
    title="Support can come from neighbors, businesses, and long-term champions."
    description="This page shows the kinds of supporters John&apos;s Table can actively invite without inventing specific logos or endorsements."
  />

  <section class="page-content">
    <div class="section__inner sponsor-grid sponsor-grid--page">
      {
        sponsorProfiles.map((item) => (
          <article class="sponsor-card" data-reveal>
            <img class="sponsor-image" src={item.image} alt={item.alt} loading="lazy" />
            <div class="sponsor-card__meta">
              <h3>{item.title}</h3>
              <p>{item.note}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-content page-content--tight">
    <div class="section__inner shell-grid">
      <article class="shell-card" data-reveal>
        <h2>Why this page exists</h2>
        <p>
          Prospective supporters need a page that explains how they can get involved and what kind of role
          they can play in helping the organization serve the community.
        </p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>What can be added over time</h2>
        <p>
          Real sponsor names, event partnerships, short impact stories, and approved logos can be layered
          into this page later without changing its structure.
        </p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>Partnership lanes</h2>
        <p>
          Meal sponsorships, in-kind support, volunteer collaborations, and neighborhood-led outreach all
          fit naturally within this public-facing framework.
        </p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>Invitation to respond</h2>
        <p>
          The contact page gives potential sponsors and partners a clear next step, which is enough for a
          demo and easy to extend into a fuller workflow later.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
