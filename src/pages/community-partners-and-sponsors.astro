---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { siteMeta } from "../data/site";
---

<BaseLayout
  title={`Community Partners & Sponsors | ${siteMeta.name}`}
  description="A page shell for future partners, sponsors, and community collaboration."
>
  <PageHero
    eyebrow="Community partners and sponsors"
    title="Space for the people and organizations that help the mission travel farther."
    description="No verified sponsor list is available yet, so this page is built as a respectful foundation rather than a padded claim page."
  />

  <section class="page-content">
    <div class="section__inner shell-grid">
      <article class="shell-card" data-reveal>
        <h2>Why this page exists</h2>
        <p>
          Future collaborators need a clear destination where sponsor recognition, partnership notes,
          and community acknowledgements can live in one place.
        </p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>What to add later</h2>
        <p>
          Confirmed sponsor names, logo treatments, event partners, and short stories about how support
          expands the reach of meals, clothing, and resource connection.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
