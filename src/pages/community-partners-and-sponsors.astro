---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { siteMeta, sponsorPlaceholders } from "../data/site";
---

<BaseLayout
  title={`Community Partners & Sponsors | ${siteMeta.name}`}
  description="A page shell for future partners, sponsors, and community collaboration."
>
  <PageHero
    eyebrow="Community partners and sponsors"
    title="A sponsor page that can hold real support without looking unfinished."
    description="These are placeholder visual blocks for future supporters. They give the page structure now and can be swapped out later for real logos, marks, or sponsor photography."
  />

  <section class="page-content">
    <div class="section__inner sponsor-grid sponsor-grid--page">
      {
        sponsorPlaceholders.map((item) => (
          <article class="sponsor-card" data-reveal>
            <img class="sponsor-image" src={item.image} alt={item.alt} loading="lazy" />
            <div class="sponsor-card__meta">
              <h3>{item.title}</h3>
              <p>{item.note}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-content page-content--tight">
    <div class="section__inner shell-grid">
      <article class="shell-card" data-reveal>
        <h2>Why this page exists</h2>
        <p>
          Future collaborators need a clear destination where recognition, partnership notes, and active
          opportunities to support the work can live in one place.
        </p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>What belongs here later</h2>
        <p>
          Confirmed sponsor names, logo treatments, event partners, volunteer crews, and short stories
          about how support expands the reach of meals, clothing, and resource connection.
        </p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>Partnership lanes</h2>
        <p>
          This structure is ready for meal sponsorships, in-kind donations, event collaborations, and
          neighborhood support from businesses, churches, and civic groups.
        </p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>Next connection</h2>
        <p>
          The contact form now gives sponsors a concrete way to reach out, even before a dedicated donor
          or CRM workflow is wired up behind the scenes.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
