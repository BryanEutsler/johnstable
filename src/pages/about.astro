---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { siteMeta } from "../data/site";
---

<BaseLayout title={`About | ${siteMeta.name}`} description="About John's Table and its community mission.">
  <PageHero
    eyebrow="About"
    title="A simple beginning for a larger community story."
    description="The live site currently shares a concise mission and vision. This page turns that material into a clearer foundation for future storytelling."
  />

  <section class="page-content">
    <div class="section__inner shell-grid">
      <article class="shell-card" data-reveal>
        <h2>Mission</h2>
        <p>{siteMeta.mission}</p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>Vision</h2>
        <p>{siteMeta.vision}</p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>What comes next</h2>
        <p>
          This shell is ready for founding story details, leadership information, community photos, and
          a fuller explanation of how John&apos;s Table serves local neighbors.
        </p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>Why this structure</h2>
        <p>
          The page avoids invented history or claims while still providing a more credible and readable
          experience than the current minimal site.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
