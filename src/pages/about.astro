---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { siteMeta } from "../data/site";
---

<BaseLayout title={`About | ${siteMeta.name}`} description="About John's Table and its community mission.">
  <PageHero
    eyebrow="About"
    title="A community-centered mission built around practical care."
    description="John's Table presents a simple public message: serve the community with meals, clothing, and resources while helping people move toward more self-sustaining futures."
  />

  <section class="page-content">
    <div class="section__inner shell-grid">
      <article class="shell-card" data-reveal>
        <h2>Mission</h2>
        <p>{siteMeta.mission}</p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>Vision</h2>
        <p>{siteMeta.vision}</p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>Community approach</h2>
        <p>
          The work begins with direct needs such as food, clothing, and practical support, then expands
          into the relationships and connections that help care continue beyond the first interaction.
        </p>
      </article>
      <article class="shell-card" data-reveal>
        <h2>Why it matters</h2>
        <p>
          A strong public presence helps neighbors understand the mission, helps supporters see where
          their help can matter, and gives partners a clearer way to connect with the organization.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
