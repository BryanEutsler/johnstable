---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { contactMethods, siteMeta } from "../data/site";
---

<BaseLayout title={`Contact | ${siteMeta.name}`} description="Get in touch with John's Table about volunteering, partnerships, donations, or community support.">
  <PageHero
    eyebrow="Contact"
    title="A clear place to start the conversation."
    description="Use this page to ask questions, explore partnerships, or start a conversation about giving and community support."
  />

  <section class="page-content">
    <div class="section__inner">
      <div class="contact-layout">
        <form class="contact-form" data-reveal>
          <div class="form-intro">
            <p class="section__eyebrow">Send a message</p>
            <h2>Tell John&apos;s Table how you would like to connect.</h2>
            <p>
              Whether you want to volunteer, explore a partnership, ask about in-kind support, or
              just learn more — this is the right place to start.
            </p>
          </div>

          <div class="field-grid">
            <div class="field">
              <label for="full-name">Full name</label>
              <input id="full-name" name="fullName" type="text" placeholder="Your name" />
            </div>
            <div class="field">
              <label for="email">Email address</label>
              <input id="email" name="email" type="email" placeholder="name@example.com" />
            </div>
            <div class="field">
              <label for="phone">Phone number</label>
              <input id="phone" name="phone" type="tel" placeholder="Optional" />
            </div>
            <div class="field">
              <label for="reason">I'm reaching out about</label>
              <select id="reason" name="reason">
                <option value="">Choose one</option>
                <option value="general">General questions</option>
                <option value="volunteer">Volunteering</option>
                <option value="sponsor">Sponsorship or partnership</option>
                <option value="donation">Donations or in-kind support</option>
              </select>
            </div>
            <div class="field field--full">
              <label for="message">Message</label>
              <textarea
                id="message"
                name="message"
                rows="7"
                placeholder="Tell John's Table how you would like to connect."
              ></textarea>
            </div>
          </div>

          <div class="form-actions">
            <button class="button button--primary" type="submit">Send message</button>
            <p class="form-note">
              We'll be in touch within a few business days.
            </p>
          </div>
        </form>

        <div class="contact-sidebar">
          <div class="contact-list">
            {
              contactMethods.map((item) => (
                <article class="contact-card" data-reveal>
                  <strong>{item.label}</strong>
                  {item.href ? <a href={item.href}>{item.value}</a> : <h2>{item.value}</h2>}
                  {item.note ? <p>{item.note}</p> : null}
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
